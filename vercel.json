{
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ],
  "buildCommand": "chmod +x frontend/vercel-build.sh && ./frontend/vercel-build.sh",
  "outputDirectory": "frontend/dist",
  "framework": "vite",
  "env": {
    "VITE_API_URL": "https://stockai-backend.onrender.com/api/v1"
  }
}